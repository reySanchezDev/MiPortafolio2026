---
import {
  resolveTechBrand,
  resolveTechDescription,
  resolveTechTone,
  techLinks,
  techNodes,
  type TechLink,
  type TechNode,
} from '../../data/tech-stack';
import type { Locale } from '../../types/content';

interface Props {
  title?: string;
  locale?: Locale;
}

type UniverseId = 'google' | 'microsoft';

type RenderableNode = TechNode & {
  renderX: number;
  renderY: number;
};

type RenderableLink = TechLink & {
  fromNode: RenderableNode;
  toNode: RenderableNode;
};

type UniverseLayout = {
  id: UniverseId;
  label: string;
  brand: string;
  focusX: number;
  focusY: number;
  nodes: RenderableNode[];
  links: RenderableLink[];
  defaultNode: RenderableNode;
};

const nodeMap = new Map(techNodes.map((node) => [node.id, node]));
const microsoftNodeIds = new Set([
  'microsoft',
  'azure',
  'csharp',
  'dotnet',
  'sqlserver',
  'powerautomate',
  'outlook',
  'teams',
  'copilot',
  'al',
  'n8n',
]);
const googleNodeIds = new Set(['google', 'flutter', 'dart', 'android', 'firebase', 'googlecloud', 'astro', 'chatfuel']);
const sharedNodeIds = new Set(['html', 'css', 'js', 'ts', 'git', 'docker', 'postgres', 'sqlite']);

const isNodeInUniverse = (nodeId: string, universeId: UniverseId) => {
  if (sharedNodeIds.has(nodeId)) return true;
  if (universeId === 'google') return googleNodeIds.has(nodeId);
  if (universeId === 'microsoft') return microsoftNodeIds.has(nodeId);
  return false;
};

const isLinkInUniverse = (from: string, to: string, universeId: UniverseId) => {
  return isNodeInUniverse(from, universeId) && isNodeInUniverse(to, universeId);
};

const hubNode = nodeMap.get('microsoft');
const googleNode = nodeMap.get('google');
const microsoftBrand = resolveTechBrand(hubNode ?? techNodes[0]);
const googleBrand = resolveTechBrand(googleNode ?? hubNode ?? techNodes[0]);
const showNodeLabels = false;
const graphOffsetX = 3.2;
const graphOffsetY = 2;
const universeOrder: UniverseId[] = ['google', 'microsoft'];
const switcherOrder: UniverseId[] = ['microsoft', 'google'];

const buildUniverseLayout = (id: UniverseId): UniverseLayout => {
  const nodes = techNodes.filter((node) => isNodeInUniverse(node.id, id));
  const xs = nodes.map((node) => node.x + graphOffsetX);
  const ys = nodes.map((node) => node.y + graphOffsetY);
  const minX = xs.length ? Math.min(...xs) : 50;
  const maxX = xs.length ? Math.max(...xs) : 50;
  const minY = ys.length ? Math.min(...ys) : 50;
  const maxY = ys.length ? Math.max(...ys) : 50;
  const targetCenterX = 50;
  const targetCenterY = 50;
  const shiftX = targetCenterX - (minX + maxX) / 2;
  const shiftY = targetCenterY - (minY + maxY) / 2;
  const renderNodes = nodes.map((node) => ({
    ...node,
    renderX: node.x + graphOffsetX + shiftX,
    renderY: node.y + graphOffsetY + shiftY,
  }));
  const renderNodeMap = new Map(renderNodes.map((node) => [node.id, node]));
  const links = techLinks
    .filter((link) => isLinkInUniverse(link.from, link.to, id))
    .map((link) => {
      const fromNode = renderNodeMap.get(link.from);
      const toNode = renderNodeMap.get(link.to);

      if (!fromNode || !toNode) return null;

      return {
        ...link,
        fromNode,
        toNode,
      };
    })
    .filter((entry): entry is RenderableLink => Boolean(entry));
  const defaultNode = (renderNodeMap.get(id === 'google' ? 'google' : 'microsoft') ?? renderNodes[0] ?? {
    ...(id === 'google' ? googleNode ?? techNodes[0] : hubNode ?? techNodes[0]),
    renderX: 50,
    renderY: targetCenterY,
  }) as RenderableNode;

  return {
    id,
    label: id === 'google' ? 'Google' : 'Microsoft',
    brand: id === 'google' ? googleBrand : microsoftBrand,
    focusX: defaultNode.renderX,
    focusY: defaultNode.renderY,
    nodes: renderNodes,
    links,
    defaultNode,
  };
};

const universeLayouts = universeOrder.map((id) => buildUniverseLayout(id));
const universeLayoutMap = new Map(universeLayouts.map((layout) => [layout.id, layout]));
const defaultUniverse: UniverseId = 'google';
const defaultLayout = universeLayoutMap.get(defaultUniverse) ?? universeLayouts[0];

const { title = '', locale = 'en' } = Astro.props;
const rootStyle = `--google-brand:${googleBrand};--microsoft-brand:${microsoftBrand};`;
---

<div class="constellation-shell" data-constellation-shell>
  <div class="constellation-card">
    <div class="constellation-topbar">
      <div class="constellation-topline">
        {title ? <p class="constellation-title">{title}</p> : null}
        <div
          class="universe-switcher"
          role="group"
          aria-label={locale === 'es' ? 'Cambiar universo del stack' : 'Switch stack universe'}
        >
          {
            switcherOrder.map((id) => {
              const layout = universeLayoutMap.get(id);

              if (!layout) return null;

              return (
              <button
                type="button"
                class:list={['universe-pill', `universe-pill-${layout.id}`]}
                data-universe-toggle
                data-universe={layout.id}
                aria-pressed={layout.id === defaultUniverse ? 'true' : 'false'}
                style={`--brand:${layout.brand};`}
              >
                {layout.label}
              </button>
              );
            })
          }
        </div>
      </div>
    </div>

    <div
      class:list={['constellation', { 'labels-hidden': !showNodeLabels }]}
      data-constellation
      data-active-universe={defaultUniverse}
      style={rootStyle}
      role="group"
      aria-label={title || (locale === 'es' ? 'Mapa de stack' : 'Stack map')}
    >
      {
        universeLayouts.map((layout) => (
          <div
            class:list={['constellation-view', `universe-${layout.id}`, { 'is-active': layout.id === defaultUniverse }]}
            data-universe-view
            data-universe={layout.id}
            aria-hidden={layout.id === defaultUniverse ? 'false' : 'true'}
            inert={layout.id === defaultUniverse ? undefined : ''}
            style={`--view-brand:${layout.brand};--focus-x:${layout.focusX};--focus-y:${layout.focusY};${layout.id === 'google' ? `--google-x:${layout.focusX};--google-y:${layout.focusY};` : `--hub-x:${layout.focusX};--hub-y:${layout.focusY};`}`}
          >
            <svg class="link-layer" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
              {
                layout.links.map((link, index) => (
                  <line
                    x1={link.fromNode.renderX}
                    y1={link.fromNode.renderY}
                    x2={link.toNode.renderX}
                    y2={link.toNode.renderY}
                    data-kind={link.kind}
                    data-universe={layout.id}
                    style={`--delay:${index * 90}ms`}
                  />
                ))
              }
            </svg>

            {
              layout.nodes.map((node, index) => (
                <button
                  type="button"
                  class:list={[
                    'node',
                    node.group ? `group-${node.group}` : undefined,
                    node.priority ? `priority-${node.priority}` : undefined,
                    {
                      compact: node.size <= 34,
                      hub: node.id === 'microsoft',
                      google: node.id === 'google',
                      subhub: node.id === 'azure',
                      'mobile-hidden': !node.showOnMobile,
                      'is-selected': node.id === layout.defaultNode.id,
                    },
                  ]}
                  data-universe={layout.id}
                  data-tech-node
                  data-tech-id={node.id}
                  data-tech-label={node.label}
                  data-tech-description={resolveTechDescription(node, locale)}
                  aria-label={node.label}
                  aria-pressed={node.id === layout.defaultNode.id ? 'true' : 'false'}
                  style={`--x:${node.renderX};--y:${node.renderY};--size:${node.size}px;--dx:${node.dx};--dy:${node.dy};--delay:${index * 80}ms;--brand:${resolveTechBrand(node)};--icon-tone-dark:${resolveTechTone(node, 'dark')};--icon-tone-light:${resolveTechTone(node, 'light')};--label-dx:${node.labelDx ?? 0}px;--label-dy:${node.labelDy ?? 0}px`}
                >
                  <span class="glyph" aria-hidden="true">
                    {node.iconSrc ? (
                      <img src={node.iconSrc} alt="" loading="lazy" decoding="async" />
                    ) : node.icon ? (
                      <svg viewBox="0 0 24 24" role="img" aria-label={node.label}>
                        <path d={node.icon.path}></path>
                      </svg>
                    ) : (
                      <strong>{node.fallback}</strong>
                    )}
                  </span>
                  {showNodeLabels ? <span class="label">{node.label}</span> : null}
                </button>
              ))
            }
          </div>
        ))
      }
    </div>

    <article class="constellation-info" data-constellation-info aria-live="polite">
      <div class="constellation-info-head">
        <p class="kicker">{locale === 'es' ? 'Detalle del stack' : 'Stack detail'}</p>
        <strong data-constellation-info-title>{defaultLayout?.defaultNode.label ?? ''}</strong>
      </div>
      <p data-constellation-info-description>{resolveTechDescription(defaultLayout?.defaultNode ?? techNodes[0], locale)}</p>
    </article>
  </div>
</div>

<script is:inline>
  (() => {
    const shells = document.querySelectorAll('[data-constellation-shell]');

    shells.forEach((shell) => {
      const root = shell.querySelector('[data-constellation]');
      const viewNodes = Array.from(shell.querySelectorAll('[data-universe-view]'));
      const toggleButtons = Array.from(shell.querySelectorAll('[data-universe-toggle]'));
      const title = shell.querySelector('[data-constellation-info-title]');
      const description = shell.querySelector('[data-constellation-info-description]');
      const defaultUniverse = 'google';
      const universeOrder = ['google', 'microsoft'];
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let activeUniverse = defaultUniverse;
      let cycleTimer = 0;
      const defaultNodeByUniverse = new Map(
        universeOrder.map((universe) => {
          const node = shell.querySelector('[data-universe-view="' + universe + '"] [data-tech-node].is-selected');

          return node ? [universe, node] : null;
        }).filter(Boolean),
      );
      const selectedNodeByUniverse = new Map(defaultNodeByUniverse);

      const setActiveNode = (nextNode, universe, persist = false) => {
        if (!nextNode || !title || !description) return;

        title.textContent = nextNode.dataset.techLabel || '';
        description.textContent = nextNode.dataset.techDescription || '';

        shell.querySelectorAll(`[data-universe-view="${universe}"] [data-tech-node]`).forEach((node) => {
          const isCurrent = node === nextNode;
          node.classList.toggle('is-selected', isCurrent);
          node.setAttribute('aria-pressed', isCurrent ? 'true' : 'false');
        });

        if (persist) {
          selectedNodeByUniverse.set(universe, nextNode);
        }
      };

      const scheduleCycle = () => {
        window.clearTimeout(cycleTimer);
        if (reduceMotion) return;

        cycleTimer = window.setTimeout(() => {
          const nextUniverse = activeUniverse === 'google' ? 'microsoft' : 'google';
          activateUniverse(nextUniverse);
        }, 5000);
      };

      const activateUniverse = (nextUniverse) => {
        activeUniverse = nextUniverse;
        if (root) root.setAttribute('data-active-universe', nextUniverse);

        viewNodes.forEach((view) => {
          const isActive = view.dataset.universe === nextUniverse;
          view.classList.toggle('is-active', isActive);
          view.setAttribute('aria-hidden', isActive ? 'false' : 'true');
          view.toggleAttribute('inert', !isActive);
        });

        toggleButtons.forEach((button) => {
          const isCurrent = button.dataset.universe === nextUniverse;
          button.setAttribute('aria-pressed', isCurrent ? 'true' : 'false');
        });

        const activeNode =
          selectedNodeByUniverse.get(nextUniverse) ||
          defaultNodeByUniverse.get(nextUniverse) ||
          shell.querySelector('[data-universe-view="' + nextUniverse + '"] [data-tech-node]');

        if (activeNode instanceof HTMLElement) {
          setActiveNode(activeNode, nextUniverse);
        }

        scheduleCycle();
      };

      window.requestAnimationFrame(() => root?.classList.add('is-ready'));
      activateUniverse(defaultUniverse);

      shell.querySelectorAll('[data-universe-view] [data-tech-node]').forEach((node) => {
        const container = node.closest('[data-universe-view]');
        const universe = container ? container.getAttribute('data-universe') : null;
        if (!universe) return;

        node.addEventListener('mouseenter', () => setActiveNode(node, universe));
        node.addEventListener('focus', () => setActiveNode(node, universe));
        node.addEventListener('click', () => {
          setActiveNode(node, universe, true);
          activateUniverse(universe);
        });
      });

      shell.querySelectorAll('[data-universe-view]').forEach((view) => {
        const universe = view.getAttribute('data-universe');
        if (!universe) return;

        view.addEventListener('mouseleave', () => {
          const selectedNode = selectedNodeByUniverse.get(universe) || defaultNodeByUniverse.get(universe);
          if (selectedNode instanceof HTMLElement) {
            setActiveNode(selectedNode, universe);
          }
        });

        view.addEventListener('focusout', (event) => {
          const selectedNode = selectedNodeByUniverse.get(universe) || defaultNodeByUniverse.get(universe);
          if (!selectedNode) return;

          const nextTarget = event.relatedTarget;
          if (!(nextTarget instanceof Node) || !view.contains(nextTarget)) {
            if (selectedNode instanceof HTMLElement) {
              setActiveNode(selectedNode, universe);
            }
          }
        });
      });

      toggleButtons.forEach((button) => {
        const universe = button.dataset.universe;
        if (!universe) return;

        button.addEventListener('click', () => {
          activateUniverse(universe);
        });
      });
    });
  })();
</script>

<style>
  .constellation-shell {
    display: block;
  }

  .constellation-card {
    position: relative;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    gap: var(--space-4);
    padding: var(--surface-padding-sm);
    border-radius: var(--radius-lg);
    border: 1px solid color-mix(in srgb, var(--stroke) 85%, transparent);
    isolation: isolate;
    background: linear-gradient(145deg, color-mix(in srgb, var(--card) 88%, transparent), color-mix(in srgb, var(--bg-2) 85%, transparent));
    overflow: hidden;
  }

  :global([data-theme='light']) .constellation-card {
    background: linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(246, 249, 253, 0.94) 56%, rgba(238, 244, 250, 0.96) 100%);
    border-color: color-mix(in srgb, var(--stroke) 96%, rgba(255, 255, 255, 0.82));
    box-shadow:
      var(--shadow-soft),
      inset 0 1px 0 rgba(255, 255, 255, 0.88),
      inset 0 -1px 0 rgba(16, 29, 47, 0.04);
  }

  .constellation-card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(circle, color-mix(in srgb, var(--muted) 18%, transparent) 0.9px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.16;
    mask: linear-gradient(180deg, transparent, black 12%, black 88%, transparent);
    pointer-events: none;
  }

  .constellation-topbar {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .constellation-topline {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
    gap: 1rem;
    min-width: 0;
  }

  .constellation-title {
    margin: 0;
    color: var(--text-0);
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .universe-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: nowrap;
    margin-inline-start: 0.12rem;
  }

  .universe-pill {
    appearance: none;
    position: relative;
    border: 1px solid color-mix(in srgb, var(--stroke) 85%, transparent);
    background: linear-gradient(180deg, color-mix(in srgb, var(--card) 98%, transparent), color-mix(in srgb, var(--bg-2) 94%, transparent));
    color: var(--text-1);
    border-radius: 999px;
    padding: 0.5rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    overflow: hidden;
  }

  .universe-pill::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent);
    opacity: 0;
    transition: opacity 300ms var(--motion-ease);
  }

  .universe-pill:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--brand) 40%, var(--stroke));
    color: var(--text-0);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  .universe-pill:hover::before {
    opacity: 1;
  }

  .universe-pill[aria-pressed='true'] {
    color: #fff;
    border-color: var(--brand);
    background: var(--brand);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--brand) 15%, transparent),
      0 15px 30px -5px color-mix(in srgb, var(--brand) 40%, transparent);
    transform: translateY(-2px) scale(1.05);
  }

  .universe-pill-microsoft[aria-pressed='true'] {
    --brand: var(--microsoft-brand);
    background: linear-gradient(135deg, #00a4ef, #0078d4);
  }

  .universe-pill-google[aria-pressed='true'] {
    --brand: var(--google-brand);
    background: linear-gradient(135deg, #4285f4, #34a853);
  }

  .constellation {
    position: relative;
    min-height: clamp(300px, 34vw, 370px);
    isolation: isolate;
    overflow: clip;
  }

  .constellation::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(circle, color-mix(in srgb, var(--muted) 18%, transparent) 0.9px, transparent 1px);
    background-size: 22px 22px;
    opacity: 0.12;
    mask: linear-gradient(180deg, transparent, black 10%, black 90%, transparent);
    pointer-events: none;
  }

  .constellation-view {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    transform: translateY(10px) scale(0.985);
    transition:
      opacity 420ms var(--motion-ease),
      transform 520ms var(--motion-ease);
    pointer-events: none;
    will-change: opacity, transform;
  }

  .constellation-view::before {
    display: none;
  }

  .universe-flag {
    position: absolute;
    top: 0.95rem;
    left: 1rem;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.34rem 0.7rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--view-brand) 24%, transparent);
    background: color-mix(in srgb, var(--card) 88%, color-mix(in srgb, var(--view-brand) 10%, transparent));
    color: var(--text-0);
    font-family: var(--font-mono);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    box-shadow:
      0 10px 22px rgba(4, 16, 30, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
    opacity: 0.68;
    pointer-events: none;
  }

  .constellation-view.is-active .universe-flag {
    opacity: 1;
  }

  .constellation-view.is-active {
    z-index: 1;
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .constellation-view.universe-microsoft.is-active {
    background: transparent;
  }

  .constellation-view.universe-google.is-active {
    background: transparent;
  }

  .constellation-view.is-active .node {
    left: calc(var(--x) * 1%);
    top: calc(var(--y) * 1%);
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    animation: node-drift 5200ms var(--motion-ease) infinite;
    animation-delay: calc(var(--delay) + 1.2s);
  }



  .constellation-view.universe-microsoft.is-active .node[data-universe='microsoft'] .glyph {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--microsoft-brand) 34%, transparent),
      0 20px 40px rgba(7, 23, 42, 0.28);
  }

  .constellation-view.universe-google.is-active .node[data-universe='google'] .glyph {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--google-brand) 34%, transparent),
      0 20px 40px rgba(7, 23, 42, 0.28);
  }

  .constellation-view:not(.is-active) .node {
    left: 50%;
    top: 50%;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.24);
    animation: none;
  }

  .constellation-view.is-active .link-layer line {
    opacity: 0.22;
    animation: line-flow 3.4s linear infinite;
    animation-delay: calc(var(--delay) + 1.05s);
  }

  .constellation-view.is-active .link-layer line[data-kind='platform'] {
    opacity: 0.38;
    stroke-width: 0.26;
    stroke: color-mix(in srgb, var(--accent-2) 36%, var(--accent) 64%);
  }

  .constellation-view.is-active .link-layer line[data-kind='core'] {
    opacity: 0.58;
    stroke-width: 0.4;
    stroke-dasharray: 1.1 1.5;
    stroke: color-mix(in srgb, var(--accent-2) 48%, var(--accent) 52%);
  }

  .constellation-view.is-active .link-layer line[data-universe='bridge'] {
    opacity: 0.14;
    stroke-width: 0.16;
    stroke-dasharray: 1.5 2.4;
    stroke: color-mix(in srgb, var(--muted) 42%, var(--accent) 58%);
  }

  .constellation-view.is-active .link-layer line[data-universe='microsoft'] {
    opacity: 0.34;
    stroke: color-mix(in srgb, var(--accent-2) 68%, var(--accent) 32%);
  }

  .constellation-view.is-active .link-layer line[data-universe='google'] {
    opacity: 0.44;
    stroke: color-mix(in srgb, var(--google-brand) 62%, var(--accent-2) 38%);
  }

  .constellation-view.is-active .link-layer line[data-universe='google'][data-kind='platform'] {
    opacity: 0.54;
    stroke-width: 0.3;
    stroke: color-mix(in srgb, var(--google-brand) 62%, var(--accent) 38%);
  }

  .constellation-view.is-active .link-layer line[data-universe='google'][data-kind='core'] {
    opacity: 0.64;
    stroke-width: 0.44;
    stroke: color-mix(in srgb, var(--google-brand) 72%, var(--accent-2) 28%);
  }

  .constellation-view.is-active .link-layer line[data-universe='microsoft'][data-kind='platform'] {
    opacity: 0.46;
    stroke-width: 0.28;
    stroke: color-mix(in srgb, var(--accent-2) 58%, var(--accent) 42%);
  }

  .constellation-view.is-active .link-layer line[data-universe='microsoft'][data-kind='core'] {
    opacity: 0.62;
    stroke-width: 0.42;
    stroke: color-mix(in srgb, var(--accent-2) 72%, var(--accent) 28%);
  }

  .constellation-view .link-layer,
  .constellation-view .node {
    position: absolute;
  }

  .constellation-info {
    position: relative;
    z-index: 1;
    min-block-size: 5.35rem;
    padding: 0;
    display: grid;
    align-content: start;
    gap: 0.25rem;
